    "Open claude.ai, read the % shown for each limit, enter it here, then Apply. Throttle adjusts each cap so the meter matches.": {
      "extractionState": "manual",
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ouvrez claude.ai, lisez le pourcentage affiché pour chaque limite, saisissez-le ici, puis Appliquer. Throttle ajuste chaque cap pour que le mètre corresponde."
          }
        }
      }
    },

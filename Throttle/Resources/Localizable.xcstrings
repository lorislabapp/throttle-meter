    "Throttle Meter does not collect telemetry.": {
      "extractionState": "manual",
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Throttle Meter ne collecte pas de télémétrie."
          }
        }
      }
    },
    "Throttle Meter reads `~/.claude/projects/` locally to compute your session-5h, weekly-all, and weekly-Sonnet usage. Nothing leaves your Mac.": {
      "extractionState": "manual",
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Throttle Meter lit `~/.claude/projects/` localement pour calculer votre utilisation session 5 h, hebdomadaire totale et hebdomadaire Sonnet. Rien ne sort de votre Mac."
          }
        }
      }
    },
    "Open claude.ai, read the % shown for each limit, enter it here, then Apply. Throttle Meter adjusts each cap so the meter matches.": {
      "extractionState": "manual",
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ouvrez claude.ai, lisez le pourcentage affiché pour chaque limite, saisissez-le ici, puis Appliquer. Throttle Meter ajuste chaque cap pour que le mètre corresponde."
          }
        }
      }
    },
